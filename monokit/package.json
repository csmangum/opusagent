{
  "name": "monokit",
  "version": "1.0.0",
  "description": "Minimalist UI kit for call analysis and conversation review",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run build-css\" \"electron .\"",
    "build": "npm run build-css && npm run build-js",
    "build-css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --watch",
    "build-js": "webpack --mode development --watch",
    "electron": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["electron", "react", "ui-kit", "call-analysis"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "electron": "^25.0.0",
    "tailwindcss": "^3.3.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}